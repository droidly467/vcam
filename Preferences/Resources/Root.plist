<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>title</key>
	<string>VCam Settings</string>
	<key>items</key>
	<array>
		<!-- Header -->
		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string>VCam — Virtual Camera QA Tool</string>
			<key>footerText</key>
			<string>Internal testing tool for simulating camera input. NOT for production use.</string>
		</dict>

		<!-- Master Toggle -->
		<dict>
			<key>cell</key>
			<string>PSSwitchCell</string>
			<key>default</key>
			<true/>
			<key>defaults</key>
			<string>com.vcam.qatool</string>
			<key>key</key>
			<string>tweakEnabled</string>
			<key>label</key>
			<string>Enable VCam</string>
			<key>PostNotification</key>
			<string>com.vcam.qatool/prefsChanged</string>
		</dict>

		<!-- Global Enable -->
		<dict>
			<key>cell</key>
			<string>PSSwitchCell</string>
			<key>default</key>
			<true/>
			<key>defaults</key>
			<string>com.vcam.qatool</string>
			<key>key</key>
			<string>globalEnabled</string>
			<key>label</key>
			<string>Global Enable</string>
			<key>PostNotification</key>
			<string>com.vcam.qatool/prefsChanged</string>
		</dict>

		<!-- App Selection -->
		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string>Target Apps</string>
			<key>footerText</key>
			<string>Select which apps will receive the simulated camera feed. If none selected, all apps are affected.</string>
		</dict>

		<dict>
			<key>cell</key>
			<string>PSLinkListCell</string>
			<key>detail</key>
			<string>VCamAppListController</string>
			<key>label</key>
			<string>App Allowlist</string>
		</dict>

		<!-- Media Source -->
		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string>Media Source</string>
			<key>footerText</key>
			<string>Place test media files in /var/jb/var/mobile/Library/VCamMedia/ and enter the filename below. Supports: jpg, png, heic, mp4, mov.</string>
		</dict>

		<dict>
			<key>cell</key>
			<string>PSSegmentCell</string>
			<key>default</key>
			<integer>0</integer>
			<key>defaults</key>
			<string>com.vcam.qatool</string>
			<key>key</key>
			<string>mediaType</string>
			<key>label</key>
			<string>Media Type</string>
			<key>validValues</key>
			<array>
				<integer>0</integer>
				<integer>1</integer>
				<integer>2</integer>
			</array>
			<key>validTitles</key>
			<array>
				<string>None</string>
				<string>Image</string>
				<string>Video</string>
			</array>
			<key>PostNotification</key>
			<string>com.vcam.qatool/prefsChanged</string>
		</dict>

		<dict>
			<key>cell</key>
			<string>PSEditTextCell</string>
			<key>default</key>
			<string></string>
			<key>defaults</key>
			<string>com.vcam.qatool</string>
			<key>key</key>
			<string>mediaFilePath</string>
			<key>label</key>
			<string>Media Filename</string>
			<key>placeholder</key>
			<string>test_video.mp4</string>
			<key>PostNotification</key>
			<string>com.vcam.qatool/prefsChanged</string>
		</dict>

		<!-- Playback Options -->
		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string>Playback Options</string>
		</dict>

		<dict>
			<key>cell</key>
			<string>PSSwitchCell</string>
			<key>default</key>
			<true/>
			<key>defaults</key>
			<string>com.vcam.qatool</string>
			<key>key</key>
			<string>loopVideo</string>
			<key>label</key>
			<string>Loop Video</string>
			<key>PostNotification</key>
			<string>com.vcam.qatool/prefsChanged</string>
		</dict>

		<dict>
			<key>cell</key>
			<string>PSSegmentCell</string>
			<key>default</key>
			<integer>2</integer>
			<key>defaults</key>
			<string>com.vcam.qatool</string>
			<key>key</key>
			<string>simulatedPosition</string>
			<key>label</key>
			<string>Camera Position</string>
			<key>validValues</key>
			<array>
				<integer>0</integer>
				<integer>1</integer>
				<integer>2</integer>
			</array>
			<key>validTitles</key>
			<array>
				<string>Front</string>
				<string>Back</string>
				<string>Both</string>
			</array>
			<key>PostNotification</key>
			<string>com.vcam.qatool/prefsChanged</string>
		</dict>

		<!-- Overlay -->
		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string>Overlay</string>
		</dict>

		<dict>
			<key>cell</key>
			<string>PSSwitchCell</string>
			<key>default</key>
			<true/>
			<key>defaults</key>
			<string>com.vcam.qatool</string>
			<key>key</key>
			<string>watermarkEnabled</string>
			<key>label</key>
			<string>Show Watermark</string>
			<key>PostNotification</key>
			<string>com.vcam.qatool/prefsChanged</string>
		</dict>

		<!-- Bypass Section -->
		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string>Bypass Detection</string>
			<key>footerText</key>
			<string>Enable to bypass KYC, liveness, anti-fraud, and anti-spoofing detection mechanisms. Hides jailbreak indicators and virtual camera signatures from detection SDKs.</string>
		</dict>

		<dict>
			<key>cell</key>
			<string>PSSwitchCell</string>
			<key>default</key>
			<false/>
			<key>defaults</key>
			<string>com.vcam.qatool</string>
			<key>key</key>
			<string>bypassDetectionEnabled</string>
			<key>label</key>
			<string>Bypass Detection</string>
			<key>PostNotification</key>
			<string>com.vcam.qatool/prefsChanged</string>
		</dict>

		<!-- Debug -->
		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string>Debug</string>
			<key>footerText</key>
			<string>Log file: /var/jb/var/mobile/Library/VCamMedia/vcam.log</string>
		</dict>

		<dict>
			<key>cell</key>
			<string>PSSwitchCell</string>
			<key>default</key>
			<true/>
			<key>defaults</key>
			<string>com.vcam.qatool</string>
			<key>key</key>
			<string>debugLogEnabled</string>
			<key>label</key>
			<string>Debug Logging</string>
			<key>PostNotification</key>
			<string>com.vcam.qatool/prefsChanged</string>
		</dict>

		<!-- Reset -->
		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string>Maintenance</string>
		</dict>

		<dict>
			<key>cell</key>
			<string>PSButtonCell</string>
			<key>label</key>
			<string>Reset All Settings</string>
			<key>action</key>
			<string>resetSettings</string>
		</dict>

		<!-- Credits -->
		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>footerText</key>
			<string>VCam v1.0.0 — Internal QA/Testing Tool
For internal testing and demonstration purposes only.</string>
		</dict>
	</array>
</dict>
</plist>

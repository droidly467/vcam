#!/bin/sh
# VCam post-removal script
# Preserves user media files, only removes log file

LOG_FILE="/var/jb/var/mobile/Library/VCamMedia/vcam.log"
LOG_OLD="/var/jb/var/mobile/Library/VCamMedia/vcam.log.old"

# Remove log files
[ -f "$LOG_FILE" ] && rm -f "$LOG_FILE"
[ -f "$LOG_OLD" ] && rm -f "$LOG_OLD"

echo "[VCam] Removed."
echo "[VCam] Media files preserved at /var/jb/var/mobile/Library/VCamMedia/"
echo "[VCam] Config preserved at /var/jb/var/mobile/Library/Preferences/com.vcam.qatool.plist"
echo "[VCam] To fully remove all data:"
echo "  rm -rf /var/jb/var/mobile/Library/VCamMedia/"
echo "  rm -f /var/jb/var/mobile/Library/Preferences/com.vcam.qatool.plist"
exit 0
